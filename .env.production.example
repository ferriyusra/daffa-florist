# ── Template environment untuk deploy Docker (docker-compose.yml) ──
# Salin ke `.env` DI SEBELAH docker-compose.yml, lalu isi nilainya:
#   cp .env.production.example .env
# Docker Compose membaca file `.env` ini otomatis untuk substitusi ${...}.

# Domain publik (untuk HTTPS Caddy). Saat tes lokal biarkan `localhost`.
DOMAIN=domainmu.com

# URL penuh aplikasi — WAJIB cocok dengan domain di atas, pakai https://.
NEXTAUTH_URL=https://domainmu.com

# Rahasia sesi NextAuth — WAJIB di production.
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=

# Kredensial Postgres (container db). Ganti password jadi yang kuat.
POSTGRES_USER=daffa
POSTGRES_PASSWORD=ganti-password-kuat
POSTGRES_DB=daffa_florist

# ── Midtrans (pembayaran) — WAJIB (lihat src/env.ts) ──
# Ambil dari dashboard Midtrans. Untuk uji pakai key Sandbox; produksi pakai
# key Production + ganti API_URL ke https://api.midtrans.com.
MIDTRANS_API_URL=https://api.sandbox.midtrans.com
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxx
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxx

# ── Resend (email reset password) — RESEND_API_KEY WAJIB di produksi ──
# Ambil dari https://resend.com (Dashboard → API Keys).
RESEND_API_KEY=re_xxxxxxxx
# Pengirim email. Domain harus terverifikasi di Resend; saat uji boleh pakai
# "Daffa Florist <onboarding@resend.dev>". Kosongkan untuk pakai default env.ts.
# EMAIL_FROM=Daffa Florist <noreply@daffa-florist.my.id>

# ── Connection pool (opsional) — kosongkan untuk pakai default env.ts ──
# DATABASE_POOL_MAX=10
# DATABASE_POOL_IDLE_TIMEOUT_MS=10000
# DATABASE_POOL_CONNECTION_TIMEOUT_MS=10000
